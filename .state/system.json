{
  "name": "ravenSDR",
  "description": "Real-time RF Signal Transcription Pipeline — RTL-SDR → Edge AI Inference (Hailo-8L NPU) → Live Web Interface",
  "version": "0.5.1",
  "status": "running",
  "license": "AGPL-3.0",
  "stack": {
    "language": "Python",
    "framework": "Flask + Flask-SocketIO",
    "sdrDemodulation": "rtl_fm (rtl-sdr-blog patched driver)",
    "webStreamIngest": "ffmpeg subprocess",
    "npuInference": "Hailo-8L via hailo-apps Python SDK",
    "speechToText": "Whisper (tiny/base .hef for Hailo)",
    "cpuFallback": "faster-whisper",
    "audioRouting": "ALSA loopback (snd-aloop)",
    "frontend": "Vanilla JS + Web Audio API",
    "realTimeComms": "Socket.IO (WebSocket)",
    "adsbDecoder": "dump1090-mutability (ADS-B 1090 MHz)",
    "mapping": "Leaflet.js + OpenStreetMap",
    "weatherParser": "NOAA NWS broadcast regex parser",
    "passPredictor": "ephem (PyEphem orbital mechanics)",
    "aptDecoder": "noaa-apt CLI (APT image decoder)",
    "hallucinationFilter": "Two-tier Whisper noise filter (phrases + structural patterns)"
  },
  "targetHardware": {
    "sbc": "Raspberry Pi 5",
    "npu": "Hailo AI Hat (Hailo-8L, 13 TOPS)",
    "sdr": "RTL-SDR Blog V4 (R828D tuner, RTL2832U, 1PPM TCXO)"
  },
  "targetOS": "Raspberry Pi OS (Bookworm, 64-bit)",
  "repository": "ravenSDR",
  "created": "2026-02-24",
